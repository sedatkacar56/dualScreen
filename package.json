{
  "name": "dual-screen-app",
  "version": "1.0.4",
  "description": "Display and sync any HTML file across multiple monitors",
  "author": "Sedat Kacar",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:portable": "electron-builder --win --config.win.target=portable",
    "build:installer": "electron-builder --win --config.win.target=nsis",
    "build:all": "electron-builder --win"
  },
  "build": {
    "appId": "com.dualscreen.app",
    "productName": "DualScreen",
    "icon": "icon.ico",
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "DualScreen",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerSidebar": null,
      "license": null,
      "runAfterFinish": true,
      "menuCategory": false,
      "guid": "dual-screen-app",
      "include": "installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "sedatkacar56",
      "repo": "dualScreen"
    },
    "files": [
      "main.js",
      "index.html",
      "picker.html",
      "video-player.html",
      "image-viewer.html",
      "icon.png",
      "icon.ico"
    ],
    "extraResources": []
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^25.1.8",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1"
  }
}
